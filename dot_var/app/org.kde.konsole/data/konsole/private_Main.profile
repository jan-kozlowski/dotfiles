DimWhenInactive=false
ErrorBackground=2
LocalTabTitleFormat=%d: %n
Name=Main
Parent=FALLBACK/
SemanticHints=2
SemanticInputClick=true
SemanticUpDown=true
ShowTerminalSizeHint=false
StartInCurrentSessionDir=false
TerminalCenter=false
TerminalColumns=120
