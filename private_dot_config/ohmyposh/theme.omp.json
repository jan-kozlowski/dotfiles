{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#11111b",
          "foreground": "#89b4fa",
          "leading_diamond": "\ue0b2",
          "properties": {
            "arch": "\uf303",
            "debian": "\uf306",
            "linux": "\ue712",
            "macos": "\ue711",
            "mint": "\uf30f",
            "raspbian": "\uf315",
            "ubuntu": "\uf31c",
            "windows": "\ue70f"
          },
          "style": "diamond",
          "template": "{{ if .WSL }}\ue712 on {{ end }}{{ .Icon }} ",
          "type": "os"
        },
        {
          "background": "#f38ba8",
          "foreground": "#11111b",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \uf09c admin ",
          "type": "root"
        },
        {
          "background": "#89b4fa",
          "background_templates": [
            "{{ if gt .Code 0 }}#f38ba8{{ end }}"
          ],
          "foreground": "#11111b",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#11111b{{ end }}"
          ],
          "leading_diamond": "\ue0b6",
          "properties": {
            "always_enabled": true
          },
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }} ",
          "trailing_diamond": "\ue0b4",
          "type": "status"
        },
        {
          "background": "#11111b",
          "foreground": "#89b4fa",
          "properties": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "template": " \uf252 {{ .FormattedMs }} ",
          "trailing_diamond": "\ue0b4",
          "type": "executiontime"
        },
        {
          "background": "#89b4fa",
          "foreground": "#11111b",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#89b4fa{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#89b4fa{{ end }}",
            "{{ if gt .Ahead 0 }}#B787D7{{ end }}",
            "{{ if gt .Behind 0 }}#B787D7{{ end }}"
          ],
          "powerline_symbol": "\ue0b0",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_worktree_count": true
          },
          "style": "powerline",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#11111b> \uf046 {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "type": "cmake",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#11111b",
          "foreground": "#89b4fa",
          "template": " \ue794 cmake {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#11111b",
          "foreground": "#89b4fa",
          "template": " \ue7a8 {{ .Full }} "
        },
        {
          "type": "angular",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#11111b",
          "foreground": "#89b4fa",
          "template": "  angular {{ .Full }} "
        },
        {
          "type": "npm",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#11111b",
          "foreground": "#89b4fa",
          "template": "  npm {{ .Full }} "
        },
        {
          "type": "tauri",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#11111b",
          "foreground": "#89b4fa",
          "template": "  tauri {{ .Full }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#89b4fa",
          "style": "plain",
          "template": "┌─",
          "type": "text"
        },
        {
          "foreground": "#89b4fa",
          "properties": {
            "folder_separator_icon": " \uf061 ",
            "home_icon": "\ueb06",
            "style": "agnoster_short",
            "max_depth": 3
          },
          "style": "diamond",
          "template": " {{ .Path }} ",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#89b4fa",
          "style": "plain",
          "template": "└─",
          "type": "text"
        },
        {
          "foreground": "#89b4fa",
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "osc99": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#89b4fa",
    "template": "\ue285 "
  },
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "#89b4fa",
    "template": "\u2570\u2500\u276f "
  },
  "version": 3
}